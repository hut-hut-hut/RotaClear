{
  "version": 2,
  "responsive": {
    "strategy": "tailwind",
    "direction": "mobile-first",
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    }
  },
  "components": {
    "UploadScreen": {
      "state": {
        "status": {
          "type": "enum",
          "values": ["idle", "analyzing", "error"],
          "default": "idle",
          "description": "Controls which UI is shown: upload button, spinner, or error message"
        }
      }
    },
    "SetupScreen": {
      "state": {
        "dropdownOpen": {
          "type": "boolean",
          "default": false,
          "description": "Whether the doctor name dropdown is visible"
        },
        "mode": {
          "type": "enum",
          "values": ["leave", "swaps"],
          "default": null,
          "description": "Which mode button is highlighted and enables the Go button"
        }
      }
    },
    "Layout": {
      "props": {
        "activeTab": {
          "type": "enum",
          "values": ["leave", "swaps", "rules"],
          "default": "leave",
          "description": "Which tab is active and underlined in the tab bar"
        }
      },
      "state": {
        "showConfirm": {
          "type": "boolean",
          "default": false,
          "description": "Whether the Remove Rota confirmation modal is visible"
        }
      }
    },
    "DayPopup": {
      "state": {
        "showEmail": {
          "type": "boolean",
          "default": false,
          "description": "When true, shows LeaveEmailModal instead of the day detail view"
        }
      }
    },
    "EmailModal": {
      "state": {
        "copied": {
          "type": "boolean",
          "default": false,
          "description": "Switches the copy button label from 'Copy to clipboard' to 'Copied!'"
        }
      }
    },
    "LeaveEmailModal": {
      "state": {
        "copied": {
          "type": "boolean",
          "default": false,
          "description": "Switches the copy button label from 'Copy to clipboard' to 'Copied!'"
        }
      }
    },
    "SwapsTab": {
      "state": {
        "selectedDate": {
          "type": "enum",
          "values": [null, "date-string"],
          "default": null,
          "description": "null shows the shift calendar; a date string switches to the swap partners list view"
        },
        "showFatiguePopup": {
          "type": "boolean",
          "default": false,
          "description": "Whether the fatigue rules explanation popup is visible"
        }
      }
    }
  },
